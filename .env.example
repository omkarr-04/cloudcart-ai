# Root environment variables for CloudCart AI
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/cloudcart
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672
JWT_ACCESS_TOKEN_SECRET=replace-with-strong-secret
JWT_REFRESH_TOKEN_SECRET=replace-with-strong-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
LOG_LEVEL=info
